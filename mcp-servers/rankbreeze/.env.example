# RankBreeze auth = your browser's _godzilla_session cookie (no API key exists).
# Option A: set it here as an env var…
RANKBREEZE_SESSION=
# Option B: or copy session.txt.example -> session.txt and paste the cookie value there.
#
# Where to get it: log in at app.rankbreeze.com -> Chrome DevTools -> Application ->
# Cookies -> app.rankbreeze.com -> copy the value of `_godzilla_session`.
