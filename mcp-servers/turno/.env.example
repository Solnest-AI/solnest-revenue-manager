# Turno External API v2 credentials (partner-gated — you already have these)
#
# CREDENTIAL MAPPING — Turno's dashboard labels are confusing:
#   TURNO_API_TOKEN  = the long JWT access token (Turno may label this your "secret key"; starts with eyJ)
#   TURNO_PARTNER_ID = the partner UUID (sent as the TBNB-Partner-ID header)
#   The short ~80-char hex value Turno calls the "API token" is the OAuth client key and is NOT used here.
TURNO_API_TOKEN=
TURNO_PARTNER_ID=

# Environment: "sandbox" (default, safe) or "production"
TURNO_ENV=sandbox

# Optional overrides (only if Turno's production host/path differs from the default)
# TURNO_BASE_URL=https://api.turnoverbnb.com
# TURNO_API_PREFIX=/v2

# Optional: set to 1 to run live sandbox integration tests
# RUN_INTEGRATION=1
